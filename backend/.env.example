# ============================================================
# APPLICATION
# ============================================================
APP_ENV=production
APP_NAME=microservice-platform
APP_VERSION=1.0.0
APP_LOG_LEVEL=info

# ============================================================
# gRPC SERVER
# ============================================================
GRPC_HOST=0.0.0.0
GRPC_PORT=50051
GRPC_MAX_RECV_MSG_SIZE=10485760
GRPC_MAX_SEND_MSG_SIZE=10485760
GRPC_KEEPALIVE_TIME=30s
GRPC_KEEPALIVE_TIMEOUT=10s
GRPC_REFLECTION_ENABLED=false

# ============================================================
# HTTP / REST GATEWAY
# ============================================================
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=30s

# ============================================================
# POSTGRESQL (Relational DB)
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=microservice_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_SSL_MODE=require
POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_CONN_MAX_LIFETIME=5m
POSTGRES_CONN_MAX_IDLE_TIME=1m
POSTGRES_MIGRATION_DIR=./migrations/postgres

# ============================================================
# MONGODB (Non-Relational DB)
# ============================================================
MONGODB_URI=mongodb://app_user:change_me_in_production@localhost:27017/microservice_db?authSource=admin
MONGODB_DB=microservice_db
MONGODB_MIN_POOL_SIZE=5
MONGODB_MAX_POOL_SIZE=50
MONGODB_MAX_CONN_IDLE_TIME=30s
MONGODB_SERVER_SELECTION_TIMEOUT=5s
MONGODB_CONNECT_TIMEOUT=10s

# ============================================================
# REDIS (Cache + Pub/Sub)
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_DB=0
REDIS_POOL_SIZE=20
REDIS_MIN_IDLE_CONNS=5
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_DEFAULT_TTL=1h

# ============================================================
# JWT / AUTH
# ============================================================
JWT_ACCESS_SECRET=change_me_to_a_strong_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_to_another_strong_secret_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=microservice-platform

# ============================================================
# TLS / CERTIFICATES
# ============================================================
TLS_ENABLED=true
TLS_CERT_FILE=/etc/certs/server.crt
TLS_KEY_FILE=/etc/certs/server.key
TLS_CA_FILE=/etc/certs/ca.crt

# ============================================================
# OBSERVABILITY
# ============================================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
PROMETHEUS_METRICS_PORT=9090
PROMETHEUS_METRICS_PATH=/metrics
HEALTH_CHECK_PORT=8081

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200

# ============================================================
# CORS
# ============================================================
CORS_ALLOWED_ORIGINS=https://yourdomain.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID
CORS_MAX_AGE=3600
